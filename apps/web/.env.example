#  App 
# PUBLIC_* vars are inlined into the browser bundle — never put secrets here.
# Schema lives in src/lib/env/schema.ts (single source of truth).
PUBLIC_APP_URL=http://localhost:4420
PUBLIC_APP_NAME=Doove

#  Analytics (PostHog) — optional 
# Leave PUBLIC_POSTHOG_KEY blank to fully disable analytics (no SDK loads).
# Project API key from PostHog → Project Settings. EU Cloud by default so
# data stays in-region. PUBLIC_POSTHOG_UI_HOST only matters for EU dashboards.
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
PUBLIC_POSTHOG_UI_HOST=https://eu.posthog.com

NODE_ENV=development
#  Database (Neon / any Postgres) 
# Connection pooling URL recommended (Neon "pooled" URL works fine with
# the `postgres` driver since we set prepare:false in src/lib/db/index.ts).
DATABASE_URL=postgresql://user:password@localhost:5432/doove

#  Better Auth 
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-32-byte-random-string
# Public URL the app is served from. In prod, must match the deployed origin.
BETTER_AUTH_URL=http://localhost:4420
# Extra origins better-auth should accept on top of BETTER_AUTH_URL.
# Comma-separated, supports wildcards (e.g. `https://*.vercel.app`).
# doove.li / doove.nexonauts.com / doove-web.vercel.app are baked in —
# only set this if you're adding a NEW host (custom domain, staging, etc.).
TRUSTED_ORIGINS=

#  OAuth providers (optional — leave blank to hide the social buttons) ─────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

#  Polar (billing — Merchant of Record) 
# Use "sandbox" while testing, "production" once Polar org is verified.
POLAR_SERVER=sandbox
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
# Product IDs created in your Polar dashboard (one per plan).
POLAR_PRODUCT_ID_PRO=

#  Email (Resend) — used for magic links and password resets ────────────
# Without RESEND_API_KEY, magic links / reset URLs are logged to stdout so
# you can copy them in local dev. Set both in production.
RESEND_API_KEY=
EMAIL_FROM=Doove <hello@doove.nexonauts.com>

#  Cloud storage (Doove Cloud video storage) ──────────────────────────
# Backed by files-sdk so the provider is swappable via one env var. Set
# STORAGE_PROVIDER to one of: r2 | s3 | cloudinary | azure | gcs. Only
# the matching block below needs values; the others can stay blank.
# Default is r2 when unset.
STORAGE_PROVIDER=r2

#  Cloudflare R2 (STORAGE_PROVIDER=r2) ──────────────────────────────────
# Create an API token under R2 → "Manage R2 API Tokens" with
# "Object Read & Write" scoped to the single bucket below.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Optional. Custom domain bound to the bucket for public reads (e.g.
# "https://cdn.doove.li"). When unset, the server always issues short-lived
# signed GETs even for `public` shares — slower but works without DNS setup.
R2_PUBLIC_URL=

#  AWS S3 (STORAGE_PROVIDER=s3) ─────────────────────────────────────────
# Also works with any S3-compatible host (MinIO, Wasabi, B2, DO Spaces)
# by setting S3_ENDPOINT. Leave S3_ENDPOINT blank for AWS itself.
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_URL=

#  Cloudinary (STORAGE_PROVIDER=cloudinary) ─────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

#  Azure Blob Storage (STORAGE_PROVIDER=azure) ──────────────────────────
# Two ways to authenticate (pick one):
#   A) Bare account name + key:
#        AZURE_STORAGE_ACCOUNT=myaccount          (name only, NOT the URL)
#        AZURE_STORAGE_KEY=<base64 account key>    (Access keys → key1, ends "==")
#   B) Full connection string in AZURE_STORAGE_ACCOUNT (carries its own key,
#      so AZURE_STORAGE_KEY can stay blank):
#        AZURE_STORAGE_ACCOUNT="DefaultEndpointsProtocol=https;AccountName=myaccount;AccountKey=<key>==;EndpointSuffix=core.windows.net"
# The key must be an ACCOUNT KEY, not a SAS token — deletes use Shared Key auth.
# AZURE_PUBLIC_URL is optional: set only for a public container / CDN
# (e.g. https://myaccount.blob.core.windows.net/mycontainer); leave blank for
# private containers (the app serves signed URLs instead).
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_BLOB_CONTAINER=
AZURE_PUBLIC_URL=

#  Google Cloud Storage (STORAGE_PROVIDER=gcs) ──────────────────────────
# Paste the full service-account JSON as a single line.
GCS_BUCKET=
GCS_SERVICE_ACCOUNT_JSON=
GCS_PUBLIC_URL=

#  Cron secret (auth for /api/cron/* endpoints) ────────────────────────
# Generate: openssl rand -base64 32
# Required to invoke the expiry sweep. Pass as ?secret=... or
# `Authorization: Bearer <secret>` from your scheduler (Vercel cron,
# Cloudflare Cron Triggers, GitHub Actions, etc.).
CRON_SECRET=
