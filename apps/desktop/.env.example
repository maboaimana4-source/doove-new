# Single .env for the desktop app — read by BOTH the Svelte frontend (Vite,Tauri)

# Prefix rule: only `PUBLIC_*` vars are exposed to the frontend bundle
# (envPrefix in vite.config.ts). Everything else is backend-only — never give a
# secret a PUBLIC_ prefix.

# Cloud API base URL (Rust auth). Dev only — release falls back to production.
CLOUD_API_URL=http://localhost:4420

# Google Drive OAuth (consumed Rust-side by commands/gdrive.rs). Secret —
# never PUBLIC_-prefixed; the frontend bundle must not see it.
GOOGLE_OAUTH_CLIENT_ID=<GOOGLE_OAUTH_CLIENT_ID>
GOOGLE_OAUTH_CLIENT_SECRET=<GOOGLE_OAUTH_CLIENT_SECRET>

# PostHog analytics — PUBLIC_ prefix so the SAME value reaches BOTH the Svelte
# frontend (Vite exposes PUBLIC_* via import.meta.env, see src/lib/env.ts) and
# the Rust backend (telemetry.rs reads PUBLIC_POSTHOG_* via std::env::var /
# option_env!). Blank = analytics disabled (no-op). PostHog ingest keys are
# publishable, so exposing this to the client bundle is intended.
PUBLIC_POSTHOG_KEY=<PUBLIC_POSTHOG_KEY>
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com



# Updater bundle signing (consumed by `tauri build` at BUILD time, not runtime).
TAURI_SIGNING_PRIVATE_KEY=<TAURI_SIGNING_PRIVATE_KEY>
TAURI_SIGNING_KEY_PASSWORD=<TAURI_SIGNING_KEY_PASSWORD>
