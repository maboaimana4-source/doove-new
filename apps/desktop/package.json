{
	"name": "doove-desktop",
	"private": true,
	"version": "0.0.0-0",
	"type": "module",
	"scripts": {
		"sync:changelog": "node ../../scripts/sync-desktop-changelog.mjs",
		"ui:dev": "pnpm sync:changelog && vite dev",
		"ui:build": "pnpm sync:changelog && vite build",
		"ui:preview": "vite preview",
		"tauri": "tauri",
		"dev": "tauri dev",
		"build": "tauri build",
		"build:debug": "tauri build --debug",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml --all",
		"fmt:check": "cargo fmt --manifest-path src-tauri/Cargo.toml --all --check",
		"lint": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
		"lint:fix": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features --fix --allow-dirty --allow-staged -- -D warnings",
		"clean:cargo": "cd src-tauri && cargo clean"
	},
	"devDependencies": {
		"@fontsource-variable/geist": "^5.2.8",
		"@internationalized/date": "^3.12.0",
		"@doove/analytics": "workspace:*",
		"@doove/design": "workspace:*",
		"@doove/ui": "workspace:*",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.1",
		"@tauri-apps/api": "^2.10.1",
		"@tauri-apps/cli": "^2.10.1",
		"@types/node": "^25.6.0",
		"shadcn-svelte": "^1.2.7",
		"sharp": "^0.34.5",
		"svelte": "^5.56.1",
		"svelte-check": "^4.4.2",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@choochmeque/tauri-plugin-sharekit-api": "^0.3.1",
		"@fontsource-variable/geist-mono": "^5.2.7",
		"@fontsource-variable/google-sans": "^5.2.1",
		"@lucide/svelte": "^0.577.0",
		"@doove/player": "workspace:*",
		"@tauri-apps/plugin-dialog": "2.6.0",
		"@tauri-apps/plugin-opener": "~2.5.4",
		"@tauri-apps/plugin-os": "^2.3.2",
		"@tauri-apps/plugin-process": "~2.3.0",
		"@tauri-apps/plugin-updater": "~2.10.1",
		"@tauri-controls-v2/svelte": "^0.4.4",
		"@unpic/svelte": "^1.0.1"
	}
}