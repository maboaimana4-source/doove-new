{
  "name": "doove",
  "private": true,
  "dependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "husky": "^9.1.7",
    "turbo": "^2.9.14"
  },
  "scripts": {
    "prepare": "husky",
    "setup:ffmpeg": "node scripts/setup.mjs",
    "dev": "turbo dev",
    "dev:desktop": "turbo dev --filter=doove-desktop",
    "dev:web": "turbo dev --filter=doove-web",
    "build": "turbo build",
    "build:desktop": "turbo build --filter=doove-desktop",
    "build:web": "turbo build --filter=doove-web",
    "build:packages": "turbo build --filter=@doove/*",
    "check": "turbo check",
    "fmt": "turbo fmt",
    "fmt:check": "turbo fmt:check",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "prepare:assets-wallpapers": "node scripts/prepare-backgrounds.mjs",
    "changeset": "changeset",
    "changeset:status": "changeset status --verbose",
    "release:prepare": "node scripts/release-prepare.mjs",
    "sync:changelog": "node scripts/sync-desktop-changelog.mjs"
  },
  "packageManager": "pnpm@10.23.0"
}