{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/kanakkholwal/recast/extensions/schema/extension.source.schema.json",
  "title": "Recast extension (source manifest)",
  "description": "Authoring form of a Recast asset-pack. Committed under extensions/packs/<id>/extension.json. The CI verifier validates it and the registry builder turns it into the installable manifest (adding per-asset url + sha256).",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "version", "kind", "permissions", "contributes", "assets"],
  "properties": {
    "$schema": { "type": "string" },
    "id": {
      "type": "string",
      "description": "Path-safe slug; must equal the pack's folder name. Mirrors is_safe_ext_id / isSafeExtId: 1-64 chars from [A-Za-z0-9._-], not leading with a dot.",
      "pattern": "^[A-Za-z0-9_-][A-Za-z0-9._-]{0,63}$"
    },
    "name": { "type": "string", "minLength": 1 },
    "version": {
      "type": "string",
      "description": "Semantic version x.y.z.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "author": { "type": "string" },
    "description": { "type": "string" },
    "kind": { "const": "asset-pack" },
    "permissions": {
      "type": "array",
      "description": "Asset-packs run no code — must be empty.",
      "maxItems": 0
    },
    "contributes": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "cursors": { "type": "array", "items": { "$ref": "#/$defs/cursor" } },
        "backgrounds": { "type": "array", "items": { "$ref": "#/$defs/background" } },
        "gradients": { "type": "array", "items": { "$ref": "#/$defs/gradient" } },
        "colors": { "type": "array", "items": { "$ref": "#/$defs/color" } },
        "easings": { "type": "array", "items": { "$ref": "#/$defs/easing" } },
        "smoothings": { "type": "array", "items": { "$ref": "#/$defs/smoothing" } }
      }
    },
    "assets": {
      "type": "array",
      "items": { "$ref": "#/$defs/asset" }
    }
  },
  "$defs": {
    "localId": { "type": "string", "pattern": "^[A-Za-z0-9_-][A-Za-z0-9._-]{0,63}$" },
    "hotspot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number", "minimum": 0, "maximum": 64 },
        "y": { "type": "number", "minimum": 0, "maximum": 64 }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "file"],
      "properties": {
        "id": { "$ref": "#/$defs/localId" },
        "file": {
          "type": "string",
          "description": "Pack-relative path to the asset file (e.g. assets/arrow.svg).",
          "pattern": "^assets/[^/\\\\]+$"
        }
      }
    },
    "cursor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "rest", "hotspot"],
      "properties": {
        "id": { "$ref": "#/$defs/localId" },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "rest": { "type": "string", "description": "Asset id of the rest-state SVG." },
        "press": { "type": "string", "description": "Asset id of the optional pressed-state SVG." },
        "hotspot": { "$ref": "#/$defs/hotspot" },
        "pressedHotspot": { "$ref": "#/$defs/hotspot" }
      }
    },
    "background": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "asset"],
      "properties": {
        "id": { "$ref": "#/$defs/localId" },
        "label": { "type": "string", "minLength": 1 },
        "asset": { "type": "string", "description": "Asset id of the full-resolution image." },
        "thumb": { "type": "string", "description": "Asset id of an optional thumbnail image." }
      }
    },
    "gradient": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "value"],
      "properties": {
        "id": { "$ref": "#/$defs/localId" },
        "label": { "type": "string", "minLength": 1 },
        "value": { "type": "string", "pattern": "gradient\\(" }
      }
    },
    "color": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "value"],
      "properties": {
        "id": { "$ref": "#/$defs/localId" },
        "label": { "type": "string", "minLength": 1 },
        "value": { "type": "string", "pattern": "^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6}|[0-9a-fA-F]{8})$" }
      }
    },
    "easing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "value"],
      "properties": {
        "id": { "$ref": "#/$defs/localId" },
        "label": { "type": "string", "minLength": 1 },
        "value": {
          "type": "object",
          "additionalProperties": false,
          "required": ["x1", "y1", "x2", "y2"],
          "properties": {
            "x1": { "type": "number" },
            "y1": { "type": "number" },
            "x2": { "type": "number" },
            "y2": { "type": "number" }
          }
        }
      }
    },
    "smoothing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "smoothing", "snapToClicks", "snapWindowMs"],
      "properties": {
        "id": { "$ref": "#/$defs/localId" },
        "label": { "type": "string", "minLength": 1 },
        "smoothing": { "type": "number", "minimum": 0, "maximum": 100 },
        "snapToClicks": { "type": "boolean" },
        "snapWindowMs": { "type": "number", "minimum": 0 }
      }
    }
  }
}
